APP_ENV=development
APP_DEFAULT_TIMEZONE=Asia/Jakarta
APP_FRONTEND_URL=http://localhost:5173

SERVER_PORT=8080
SERVER_READ_TIMEOUT=15s
SERVER_WRITE_TIMEOUT=15s
SERVER_SHUTDOWN_TIMEOUT=10s

DB_HOST=localhost
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=25
DB_CONN_MAX_LIFETIME=5m

JWT_SECRET=replace_with_a_long_random_secret
JWT_ISSUER=jobjourney
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Origin,Content-Type,Authorization,X-Timezone,X-Request-ID

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=JobJourney

AUTH_VERIFY_TOKEN_TTL=24h
AUTH_RESET_TOKEN_TTL=1h
